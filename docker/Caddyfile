{
  email {$ACME_EMAIL}
  on_demand_tls {
    ask http://web:3000/internal/domain-check
    interval 2m
    burst 5
  }
}

# Main frontend
{$APP_DOMAIN} {
  reverse_proxy web:3000
}

# REST API
api.{$APP_DOMAIN} {
  reverse_proxy api:3001
}

# WebSocket server
ws.{$APP_DOMAIN} {
  reverse_proxy ws:3002
}

# On-demand TLS for user-connected custom domains
:443 {
  tls {
    on_demand
  }
  reverse_proxy web:3000 {
    header_up X-Forwarded-For {http.request.remote}
    header_up X-Forwarded-Proto {http.request.scheme}
    header_up X-Forwarded-Host {http.request.host}
  }
}

:80 {
  redir https://{host}{uri}
}
