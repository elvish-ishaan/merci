{
    email {$ACME_EMAIL}
    on_demand_tls {
        ask http://api:3001/internal/domain-check
    }
}

# Main frontend
{$APP_DOMAIN} {
    tls {
        issuer acme {
            disable_tlsalpn_challenge
        }
    }
    reverse_proxy web:3000
}

# REST API
api.{$APP_DOMAIN} {
    tls {
        issuer acme {
            disable_tlsalpn_challenge
        }
    }
    reverse_proxy api:3001
}

# WebSocket server
ws.{$APP_DOMAIN} {
    tls {
        issuer acme {
            disable_tlsalpn_challenge
        }
    }
    reverse_proxy ws:3002
}

# On-demand TLS for user-connected custom domains
# This handles any domain not matched above
:443 {
    tls {
        on_demand
    }
    # Caddy automatically handles X-Forwarded-* headers perfectly
    reverse_proxy api:3001
}