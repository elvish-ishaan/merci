# ─── Domain ──────────────────────────────────────────────────────────────────
# Your production domain (no https://)
APP_DOMAIN=yourdomain.com
# Email used by Caddy for Let's Encrypt certificate registration
ACME_EMAIL=admin@yourdomain.com

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-this-to-a-secure-password
POSTGRES_DB=mercy

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret
# Shared secret between mercob (job scheduler) and the api internal endpoints
WORKER_SECRET=change-this-to-a-long-random-secret

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be identical in api and worker
ENV_ENCRYPTION_KEY=your-64-char-hex-key-here

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Set the callback URL to: https://api.yourdomain.com/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.yourdomain.com/auth/github/callback

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=merci

# ─── Frontend public URLs ─────────────────────────────────────────────────────
# NOTE: NEXT_PUBLIC_* variables are baked into the Next.js bundle at build time.
# These must be set correctly before building the merci-web Docker image.
# If you change the domain, rebuild the image with these values.
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://ws.yourdomain.com
