generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  password          String
  createdAt         DateTime         @default(now())
  projects          Project[]
  mercioFunctions   MercioFunction[]
  scheduledJobs     ScheduledJob[]
  githubId          String?          @unique
  githubAccessToken String?
}

model Project {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  repoUrl       String
  projectName   String
  status        ProjectStatus  @default(QUEUED)
  bucketPrefix  String?
  deployedUrl   String?
  subdomain     String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  envVars       EnvVar[]
  buildLogs     BuildLog[]
  customDomains CustomDomain[]
}

model BuildLog {
  id        Int      @id @default(autoincrement())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  line      String
  stream    String   @default("stdout")
  createdAt DateTime @default(now())

  @@index([projectId])
}

model EnvVar {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key            String
  encryptedValue String
  createdAt      DateTime @default(now())
}

model MercioFunction {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  entry        String         @default("index.js")
  status       MercioStatus   @default(QUEUED)
  bundleKey    String?
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  scheduledJobs ScheduledJob[]

  @@index([userId])
}

model ScheduledJob {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  functionId   String
  function     MercioFunction @relation(fields: [functionId], references: [id], onDelete: Cascade)
  name         String
  active       Boolean      @default(true)
  recurring    Boolean      @default(true)

  scheduleKind ScheduleKind
  timeOfDay    String?
  daysOfWeek   Int[]
  intervalSec  Int?
  cronExpr     String?
  runAt        DateTime?

  method       String       @default("GET")
  path         String       @default("/")
  query        Json?
  headers      Json?
  body         String?

  maxRetries   Int          @default(0)
  timeoutMs    Int          @default(30000)

  nextRunAt    DateTime
  lastRunAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  runs         JobRun[]

  @@index([active, nextRunAt])
  @@index([userId])
}

model JobRun {
  id           String       @id @default(uuid())
  jobId        String
  job          ScheduledJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  attempt      Int          @default(1)
  status       JobRunStatus @default(QUEUED)
  scheduledFor DateTime
  startedAt    DateTime?
  finishedAt   DateTime?
  durationMs   Int?
  httpStatus   Int?
  responseBody String?
  errorMessage String?
  logs         JobRunLog[]
  createdAt    DateTime     @default(now())

  @@index([jobId, createdAt])
}

model JobRunLog {
  id        BigInt   @id @default(autoincrement())
  runId     String
  run       JobRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  line      String
  stream    String   @default("stdout")
  createdAt DateTime @default(now())

  @@index([runId])
}

enum MercioStatus {
  QUEUED
  BUILDING
  DEPLOYED
  FAILED
}

enum ProjectStatus {
  QUEUED
  CLONING
  BUILDING
  DEPLOYED
  FAILED
}

enum DomainSslStatus {
  PENDING
  PROVISIONING
  ACTIVE
  FAILED
}

enum ScheduleKind {
  DAILY
  WEEKLY
  INTERVAL
  ONCE
  CRON
}

enum JobRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  TIMEOUT
}

model CustomDomain {
  id        String          @id @default(uuid())
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domain    String          @unique
  verified  Boolean         @default(false)
  sslStatus DomainSslStatus @default(PENDING)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([projectId])
}
