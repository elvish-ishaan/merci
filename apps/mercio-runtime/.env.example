R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="merci"

REDIS_HOST="localhost"
REDIS_PORT="6379"

# Directory where worker.mjs files and capnp configs are cached on disk
MERCIO_CACHE_DIR="/tmp/mercio"

# Optional tuning
# MERCIO_POOL_MAX=20
# MERCIO_IDLE_TTL_MS=300000
# WORKERD_BIN=/path/to/workerd
